# Analysis API key (https://aistudio.google.com/apikey)
VITE_GEMINI_API_KEY=your_api_key_here

# Optional: dedicated key for Google Safe Browsing (Chrome blocklist) — enable Safe Browsing API in Google Cloud
# If omitted, VITE_GEMINI_API_KEY is used when Safe Browsing API is enabled on the same project
VITE_SAFE_BROWSING_API_KEY=
